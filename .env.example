# Copiați acest fișier în „.env" pentru dezvoltare locală, sau folosiți aceste
# variabile în panoul host-ului (Render / Railway / VPS) pentru producție.

# Portul serverului (implicit 3000)
PORT=3000

# Adresa publică, fără slash la final. Este folosită pentru linkurile private
# de urmărire trimise prin SMS și email (obligatorie pe un domeniu propriu/VPS).
# Pe Railway și Render aplicația detectează și domeniul public al platformei.
APP_BASE_URL=https://comenzi.exemplu.ro

# Cheie de browser Google Maps: Maps JavaScript + Places + Geocoding.
# Proiectul Google Cloud TREBUIE să aibă Billing activ (altfel: BillingNotEnabledMapError).
# Restricționeaz-o în Google Cloud la domeniul aplicației și localhost pentru dezvoltare.
GOOGLE_MAPS_BROWSER_API_KEY=

# Parola panoului de administrare — OBLIGATORIE în producție.
# Serverul refuză să pornească în producție cu parola implicită.
ADMIN_PASSWORD=schimbati-aceasta-parola

# Baza de date PostgreSQL. Dacă NU este setată, aplicația folosește un fișier
# JSON local (data/db.json) — doar pentru dezvoltare, nu pentru producție.
# DATABASE_URL=postgres://user:parola@host:5432/granafarm

# Notificări SMS prin Twilio (opțional). Fără ele, SMS-urile rulează simulat.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+1xxxxxxxxxx
